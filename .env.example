# Copy this file to .env and fill in values for local development.
# In Replit: add these as Secrets (lock icon). In other hosts: use their env var UI.
# Never commit .env to git.

# Required — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/outboundos

# Session & Auth
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BRIAN_EMAIL=

# Optional — overrides auto-detected app URL (needed if redirect URI isn't auto-detected correctly)
# APP_BASE_URL=https://your-app-url.com
# Use the same host you open in the browser (localhost vs 127.0.0.1) so OAuth return URLs match the session cookie.

# Optional — HTTPS logo URL for OAuth consent (Superhuman requires https; omitted when APP_BASE_URL is http://localhost).
# OAUTH_CLIENT_LOGO_URL=https://your-cdn.com/outbound-os-logo.svg

# Optional — custom encryption key for stored OAuth tokens (auto-derived from DATABASE_URL if not set)
# ENCRYPTION_KEY=some-random-32-char-string

# Optional
# PORT=5000
# OPENAI_API_KEY=
# N8N_WEBHOOK_URL=
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=

# Phase 2 — Agent & MCP
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=outboundos
LANGCHAIN_TRACING_V2=false
# Superhuman remote MCP endpoint (default if empty: https://mcp.mail.superhuman.com/mcp)
SUPERHUMAN_MCP_URL=
# Superhuman sync mode: mock (default) or live
# RELATIONSHIP_PROVIDER_MODE=mock
# Pagination/backpressure limits for live Superhuman sync
# SUPERHUMAN_MAX_PAGES_PER_SYNC=20
# SUPERHUMAN_MAX_THREADS_PER_SYNC=1000
# MCP retry tuning for transient errors
# SUPERHUMAN_MCP_MAX_RETRIES=3
# SUPERHUMAN_MCP_RETRY_BASE_MS=250
GRANOLA_MCP_URL=
GCAL_MCP_URL=
