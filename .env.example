# Copy this file to .env and fill in values for local development.
# In Replit: add these as Secrets (lock icon). In other hosts: use their env var UI.
# Never commit .env to git.

# Required — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/outboundos

# Session & Auth
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BRIAN_EMAIL=

# Optional — overrides auto-detected app URL (needed if redirect URI isn't auto-detected correctly)
# APP_BASE_URL=https://your-app-url.com

# Optional — custom logo URL for OAuth consent screens (Superhuman MCP). Defaults to /brand/outbound-os-mark.svg on APP_BASE_URL.
# OAUTH_CLIENT_LOGO_URL=https://your-cdn.com/outbound-os-mark.png

# Optional — custom encryption key for stored OAuth tokens (auto-derived from DATABASE_URL if not set)
# ENCRYPTION_KEY=some-random-32-char-string

# Optional
# PORT=5000
# OPENAI_API_KEY=
# N8N_WEBHOOK_URL=
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=

# Phase 2 — Agent & MCP
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=outboundos
LANGCHAIN_TRACING_V2=false
# Superhuman remote MCP endpoint (default if empty: https://mcp.mail.superhuman.com/mcp)
SUPERHUMAN_MCP_URL=
GRANOLA_MCP_URL=
GCAL_MCP_URL=
